generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  ESTUDIANTE
  UNIVERSIDAD
  EMPRESA
}

enum EstadoDocumento {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum TipoDocumento {
  INICIACION
  INFORME_1
  INFORME_2
  INFORME_3
  INFORME_FINAL
}

// ─── MODELOS NEXTAUTH ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USUARIO CENTRAL ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(ESTUDIANTE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // SIGP-IT relations
  perfilEstudiante  PerfilEstudiante?
  perfilUniversidad PerfilUniversidad?
  perfilEmpresa     PerfilEmpresa?
  notificaciones    Notificacion[]
}

// ─── PERFILES POR ROL ──────────────────────────────────────

model PerfilEstudiante {
  id         String  @id @default(cuid())
  userId     String  @unique
  codigoUsta String? @unique
  programa   String?
  semestre   Int?
  telefono   String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  practicas Practica[]
}

model PerfilUniversidad {
  id           String  @id @default(cuid())
  userId       String  @unique
  departamento String?
  cargo        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerfilEmpresa {
  id            String   @id @default(cuid())
  userId        String   @unique
  nombreEmpresa String
  nit           String?  @unique
  sector        String?
  ciudad        String?
  telefono      String?
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  practicas Practica[]
}

// ─── MÓDULO PRÁCTICAS ─────────────────────────────────────

model Practica {
  id               String    @id @default(cuid())
  estudianteId     String
  empresaId        String
  fechaInicio      DateTime
  fechaFin         DateTime?
  descripcionCargo String?
  activa           Boolean   @default(true)
  quedoContratado  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  estudiante PerfilEstudiante @relation(fields: [estudianteId], references: [id])
  empresa    PerfilEmpresa    @relation(fields: [empresaId], references: [id])
  documentos Documento[]
}

// ─── MÓDULO DOCUMENTOS ────────────────────────────────────

model Documento {
  id            String          @id @default(cuid())
  practicaId    String
  titulo        String
  descripcion   String?
  archivoUrl    String
  estado        EstadoDocumento @default(PENDIENTE)
  comentarios   String?         @db.Text
  firmadoUrl    String?
  tipoDocumento TipoDocumento?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  practica Practica @relation(fields: [practicaId], references: [id], onDelete: Cascade)
}

// ─── MÓDULO NOTIFICACIONES ────────────────────────────────

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  tipo      String
  enlace    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
